---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import CTABanner from "../components/CTABanner.astro";

/* Guide cover images — exact Framer assets from askbobai.com/resources-guides. */
const guides = [
  {
    slug: "business-intelligence-in-ai",
    title: "Business Intelligence in AI",
    excerpt: "Business Intelligence (BI) helps organizations convert raw data into actionable insights. Learn strategies to improve reporting, analytics, and decision-making.",
    category: "Intelligence",
    image: "/images/framer/Z1CrIWhAwgVYiJGDkcjcSXkJVcw.png",
  },
  {
    slug: "mortgage-ai-handbook",
    title: "Mortgage AI Handbook With Over 100+ Roles",
    excerpt: "The Mortgage AI Handbook explains how AI supports 100+ roles across the mortgage industry, from loan officers and underwriters to compliance teams.",
    category: "Mortgage",
    image: "/images/framer/CIRW2cm7WRipiBQvf3PIsaoNlWU.png",
  },
  {
    slug: "ultimate-guide-ai-ceos",
    title: "The Ultimate Guide To AI for CEOs",
    excerpt: "Learn how CEOs can use artificial intelligence to improve strategy, decision-making, and organizational performance in this comprehensive AI guide.",
    category: "Leadership",
    image: "/images/framer/RpdXR5ELbME3lu853zXnIcbQj8Y.png",
  },
];
---

<Layout title="AskBob AI — Guides" description="AI insights and guides for CEOs and executives navigating change and leading in the age of AI.">
  <Hero
    eyebrow="Guides"
    heading="When Everyone Knows, Everyone Moves."
    subheading="Because growth stalls when knowledge is fragmented. These guides help you align your teams, operationalize AI, and move as one."
    ctaLabel={undefined}
  />

  <section class="bg-white py-20 lg:py-24">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10 grid md:grid-cols-3 gap-8">
      {guides.map(g => (
        /* Detail pages (/resources-guides/<slug>) aren't built yet — render
           as a non-interactive article card until they exist. */
        <article class="block rounded-2xl overflow-hidden border border-black/5">
          <div class="aspect-[16/10] overflow-hidden bg-blue-bg">
            <img src={g.image} alt={g.title} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="p-6">
            <span class="text-xs font-semibold text-brand uppercase tracking-wider">{g.category}</span>
            <h2 class="mt-2 text-xl font-bold leading-tight">{g.title}</h2>
            <p class="mt-3 text-sm text-ink-muted leading-relaxed">{g.excerpt}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <CTABanner heading="Get Started Today!" />
</Layout>
