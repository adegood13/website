---
import Layout from "../../../layouts/Layout.astro";
import Hero from "../../../components/Hero.astro";
import ClientScroller from "../../../components/ClientScroller.astro";
import FeatureSplit from "../../../components/FeatureSplit.astro";
import FeatureCards from "../../../components/FeatureCards.astro";
import Stats from "../../../components/Stats.astro";
import CTABanner from "../../../components/CTABanner.astro";

const capabilities = [
  { icon: "🔍", title: "Make knowledge searchable",    body: "Guidelines, overlays, SOPs, and internal docs become instantly accessible." },
  { icon: "⚡", title: "Get answers inside workflows", body: "Deliver answers through helpdesk, email, SMS, or embedded chat." },
  { icon: "✅", title: "Stay consistent and defensible", body: "Standardize responses for underwriting, QC, and compliance teams." },
];
---

<Layout title="AskBobAI — Mortgage Industry" description="AI for mortgage teams—AskBobAI turns guidelines, overlays, and internal policies into instant answers that speed up decisions.">
  <Hero
    eyebrow="Mortgage"
    heading="AI For Mortgage Teams."
    subheading="Instant clarity on guidelines, overlays, and next steps—so every loan keeps moving forward."
    ctaLabel="Start a Free Trial"
  />

  <!-- Client strip -->
  <section class="bg-white py-16 lg:py-20">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10 text-center">
      <h2 class="text-2xl lg:text-3xl font-bold tracking-tight max-w-2xl mx-auto">
        Trusted By Lenders. Built To Work across Your Mortgage Tech Stack.
      </h2>
      <div class="mt-8">
        <ClientScroller />
      </div>
    </div>
  </section>

  <FeatureSplit
    heading="Your mortgage knowledge is fragmented"
    body="AskBobAI makes your mortgage data searchable, usable, and actionable — instantly."
    image="/images/framer-assets/k45eD1b4A1P0f5cPmUjFeSnGOVU.png"
    imageAlt="Mortgage dashboard"
    background="blue"
    ctaLabel="Get Demo"
  />

  <FeatureCards
    heading="Built for teams that need speed,"
    headingAccent="accuracy, and consistency."
    cards={capabilities}
    background="white"
    cardBackground="blue"
  />

  <FeatureSplit
    heading="More than guideline search."
    body="AskBobAI is a mortgage data platform that turns scattered knowledge into instant, actionable answers."
    image="/images/framer-assets/k45eD1b4A1P0f5cPmUjFeSnGOVU.png"
    imageAlt="Guideline search"
    background="blue"
    reversed
  />

  <Stats />

  <CTABanner
    heading="Make Your Mortgage Data Instantly Usable"
    subheading="Ready to transform your industry with AI? Take the leap and unlock the power of AskBob AI today. Elevate your customer experience, streamline your processes."
    ctaLabel="Schedule Demo"
  />
</Layout>
