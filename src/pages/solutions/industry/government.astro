---
import Layout from "../../../layouts/Layout.astro";
import Hero from "../../../components/Hero.astro";
import FeatureSplit from "../../../components/FeatureSplit.astro";
import Stats from "../../../components/Stats.astro";
import CTABanner from "../../../components/CTABanner.astro";
---

<Layout title="AskBobAI — Government Industry" description="AI for government teams—AskBobAI turns policies, procedures, and internal knowledge into instant answers that save time.">
  <Hero
    eyebrow="Government"
    heading="Built For The Pace And Responsibility Of Government"
    subheading="AskBob gives government teams the clarity they need to protect, serve, and support communities."
  />

  <FeatureSplit
    heading="Modernize government services without disrupting the mission"
    body="Respond faster to threats, disasters, and citizen needs — while keeping the chain of custody and audit trail intact."
    image="/images/banking-workstation.png"
    imageAlt="Government team"
    background="white"
  />

  <FeatureSplit
    heading="Confidence for every public decision"
    body="AskBob delivers trusted answers across systems so agencies move quickly without compromising security or oversight."
    image="/images/framer-assets/k45eD1b4A1P0f5cPmUjFeSnGOVU.png"
    imageAlt="Decision support"
    background="blue"
    reversed
    ctaLabel="See it in action"
  />

  <Stats />

  <CTABanner
    heading="Explore Your AI Government Solution"
    subheading="Ready to transform your industry with AI? Take the leap and unlock the power of AskBob AI today. Elevate your customer experience, streamline your processes."
    ctaLabel="Schedule Demo"
  />
</Layout>
