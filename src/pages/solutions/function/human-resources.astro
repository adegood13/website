---
import Layout from "../../../layouts/Layout.astro";
import Hero from "../../../components/Hero.astro";
import FunctionPageBody from "../../../components/FunctionPageBody.astro";
import Stats from "../../../components/Stats.astro";
import CTABanner from "../../../components/CTABanner.astro";
---

<Layout title="AskBobAI — Human Resources Function" description="AI for HR teams—AskBobAI turns policies, benefits, and onboarding knowledge into instant answers employees trust.">
  <Hero
    eyebrow="Human Resources"
    heading="AskBob: Your Human Resources Expert."
    subheading="AskBob coordinates specialized agents, tools, and reasoning to solve complex, multi-step business problems."
  />

  <FunctionPageBody
    sampleQuestions={[
      "When do my retirement benefits start?",
      "What is our PTO policy?",
      "How can I change my direct deposit information?",
      "How do I enroll in health insurance?",
    ]}
    coreHeading="One source of truth for people's policies—available when it matters."
    coreBody="AskBob helps HR teams answer employee questions consistently across handbooks, benefits docs, policies, and internal procedures. Employees get fast, accurate answers."
    helpsWith={[
      "Answering policy and benefits questions",
      "Supporting onboarding and training",
      "Reducing repetitive HR tickets",
      "Ensuring consistent, compliant responses",
    ]}
    whyChooseHeading="Why HR Teams Choose AskBob"
    whyChoose={[
      "Answers are grounded in official documents",
      "Updates automatically as policies change",
      "Works in chat, email, and support tools",
      "Reduces burnout while improving employee experience",
    ]}
  />

  <Stats />

  <CTABanner
    heading="Get your Human Resources Function Started Today!"
    subheading="Experience the power of function-specific language models firsthand! Kickstart your journey towards enhanced efficiency and precision by scheduling a demo."
    ctaLabel="Schedule Demo"
  />
</Layout>
