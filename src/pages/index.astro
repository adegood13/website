---
/**
 * Home page — pixel-perfect port of the Framer original.
 * All copy matches the scraped Apr 2026 source; swap in real stats/labels
 * as needed (stat values are best-guess until confirmed).
 */
import Layout from "../layouts/Layout.astro";
import GetDemoButton from "../components/GetDemoButton.astro";
import ClientScroller from "../components/ClientScroller.astro";

/* Stats copy lifted verbatim from askbobai.com — label + description per card. */
const stats = [
  { label: "Hours Saved",         body: "Fewer repeat questions, escalations, and internal back-and-forth." },
  { label: "Answer Accuracy",     body: "Answer-first responses grounded in your knowledge—consistent and defensible." },
  { label: "Knowledge Base Usage", body: "Instant answers that drive real adoption inside your workflow." },
];

/* Workflow cards use the exact Framer illustrations pulled from askbobai.com. */
const workflowCards = [
  {
    image: "/images/framer/ybacwKKcJp67qwSol4tUrN5Ig.webp",
    imageAlt: "Bottleneck",
    title: "Bottlenecks show up everywhere",
    body: "Guidelines, docs, and tickets slow decisions down.",
  },
  {
    image: "/images/framer/hHqPStblDEV8jGMkRVoFnOKl7c.webp",
    imageAlt: "Salesforce and Help Scout Logo signs",
    title: "AskBob plugs into your workflow",
    body: "No new tools. No process change.",
  },
  {
    image: "/images/framer/k45eD1b4A1P0f5cPmUjFeSnGOVU.png",
    imageAlt: "Screenshot of an interface for editing the AI agent's response settings for a specific question.",
    title: "Answers become instant and consistent",
    body: "Cited, traceable responses your team can stand behind.",
  },
];

/* Industry tab content — Framer's static HTML only ships the Banking
   variant's image; other tabs reuse it visually until confirmed. */
const industries = [
  { id: "banking",    label: "Banking",    title: "Banking, made intuitive",    body: "AskBob helps banking teams deliver fast, accurate responses that keep customers engaged and transactions moving.", image: "/images/framer/EajKAdMTugjBB2TTZllzwuhACcg.png" },
  { id: "mortgage",   label: "Mortgage",   title: "Mortgage, simplified",        body: "Guideline-grounded answers for LOs, processors, and underwriters — right inside the tools they already use.", image: "/images/framer/EajKAdMTugjBB2TTZllzwuhACcg.png" },
  { id: "insurance",  label: "Insurance",  title: "Claims clarity, instantly",   body: "Policy-aware answers that help adjusters and agents respond faster and more consistently.", image: "/images/framer/EajKAdMTugjBB2TTZllzwuhACcg.png" },
  { id: "government", label: "Government", title: "Citizen service that scales", body: "Secure, auditable AI that helps agencies respond to constituents with accuracy and trust.", image: "/images/framer/EajKAdMTugjBB2TTZllzwuhACcg.png" },
  { id: "retail",     label: "Retail",     title: "Retail support, accelerated", body: "Turn product and policy knowledge into instant answers for associates and customers alike.", image: "/images/framer/EajKAdMTugjBB2TTZllzwuhACcg.png" },
  { id: "saas",       label: "SaaS",       title: "SaaS support, supercharged",  body: "Product knowledge, release notes, and troubleshooting — grounded answers for CS and engineering.", image: "/images/framer/EajKAdMTugjBB2TTZllzwuhACcg.png" },
];
---

<Layout
  title="AskBobAI — #1 Knowledge Management platform for work"
  description="The #1 AI platform for any department— turning your company knowledge into instant answers that save time and money."
>
  <!-- =============================================================
       HERO  (exact match to live askbobai.com hero)
       - Full-bleed blue gradient that fades to white at bottom
       - Nav sits transparently ON TOP of this section (no bar)
       - H1 line 1: static "AI for Every Function" (white)
       - H1 line 2: animated mint-green word that cycles through
         {Sales, Finance, HR, Marketing, Operations, Support,
          Technology, Legal, Procurement}
       - Two CTAs: "Watch Video" (opens modal) + "Get a Demo"
       ============================================================= -->
  <section class="bg-hero-gradient relative overflow-hidden pt-28 lg:pt-36">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10 pt-20 pb-32 lg:pt-24 lg:pb-44 text-center relative z-10">
      <h1 class="text-white font-semibold tracking-tight text-[44px] sm:text-6xl lg:text-[64px] leading-[1.08]">
        AI for Every Function
        <br />
        <span
          id="cycle-word"
          class="inline-block text-[#99f0bd] hero-typer"
          aria-live="polite"
        ><span id="cycle-word-text"></span><span
          id="cycle-word-caret"
          aria-hidden="true"
          class="hero-typer-caret"
        ></span></span>
      </h1>
      <p class="mt-6 text-lg lg:text-xl text-white/90 max-w-xl mx-auto leading-relaxed">
        AskBob brings speed to your customers and time back to your teams.
        Instant, trusted answers — right where work happens.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center items-center">
        <button
          type="button"
          id="hero-watch-video"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-white/60 bg-white/5 text-white font-semibold hover:bg-white hover:text-ink transition-colors"
        >
          Watch Video
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
        </button>
        <GetDemoButton size="md" />
      </div>
    </div>
  </section>

  <!-- Video modal (hidden until "Watch Video" is clicked) -->
  <dialog
    id="video-modal"
    class="backdrop:bg-black/80 rounded-2xl p-0 max-w-5xl w-[92vw] bg-transparent border-0"
  >
    <div class="relative aspect-video w-full rounded-2xl overflow-hidden bg-black shadow-2xl">
      <button
        type="button"
        id="video-modal-close"
        class="absolute top-4 right-4 z-10 w-10 h-10 rounded-full bg-white/90 text-ink flex items-center justify-center hover:bg-white transition-colors"
        aria-label="Close video"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
      <video
        id="video-modal-player"
        controls
        preload="none"
        playsinline
        poster="/videos/commercial-poster.jpg"
        class="w-full h-full object-cover"
      >
        <source src="/videos/commercial.webm" type="video/webm" />
        <source src="/videos/commercial.mp4" type="video/mp4" />
      </video>
    </div>
  </dialog>

  <!-- =============================================================
       TRUSTED ACROSS INDUSTRIES
       ============================================================= -->
  <section class="bg-white py-20 lg:py-24">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
      <div class="text-center max-w-3xl mx-auto mb-10">
        <h2 class="text-4xl lg:text-[54px] font-bold tracking-tight leading-[1.1]">Trusted Across Industries</h2>
        <p class="mt-4 text-ink-muted text-lg">
          AskBob powers knowledge-driven teams across industries where accuracy, speed, and trust matter most.
        </p>
      </div>
      <ClientScroller />
      <div class="text-center mt-10">
        <GetDemoButton label="Get a Demo" />
      </div>
    </div>
  </section>

  <!-- =============================================================
       RESULTS YOU CAN MEASURE
       Matches askbobai.com exactly: eyebrow "Put Your Knowledge to Work",
       heading "Results You Can Measure", and three benefit cards with a
       short description per card (no hero-numeric counter — the live site
       uses a qualitative pattern here, not numbers).
       ============================================================= -->
  <section class="bg-blue-bg py-20 lg:py-28">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand mb-3">Put Your Knowledge to Work</p>
        <h2 class="text-4xl lg:text-[54px] font-bold tracking-tight leading-[1.1]">
          Results <span class="text-brand">You Can Measure</span>
        </h2>
        <p class="mt-4 text-ink-muted text-lg">
          No hype. Just real impact your team will feel in week one.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {stats.map(stat => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-black/5 flex flex-col gap-4">
            <h3 class="text-2xl font-bold tracking-tight text-ink">{stat.label}</h3>
            <p class="text-ink-muted leading-relaxed">{stat.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- =============================================================
       HOW ASKBOBAI FITS INTO YOUR WORKFLOW
       ============================================================= -->
  <section id="how-it-works" class="bg-white py-20 lg:py-28">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <h2 class="text-4xl lg:text-5xl font-bold tracking-tight">
          How AskBobAI <span class="text-brand">Fits Into Your Workflow</span>
        </h2>
        <p class="mt-4 text-ink-muted text-lg">
          From bottlenecks to instant answers — without changing how your team works.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {workflowCards.map(card => (
          <div class="bg-blue-bg rounded-3xl p-8 flex flex-col gap-5 overflow-hidden">
            <div class="aspect-[4/3] rounded-xl bg-white/60 flex items-center justify-center overflow-hidden">
              <img src={card.image} alt={card.imageAlt} class="max-w-[85%] max-h-[85%] object-contain" loading="lazy" />
            </div>
            <h3 class="text-xl font-bold">{card.title}</h3>
            <p class="text-ink-muted leading-relaxed text-sm">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- =============================================================
       INDUSTRY TABS
       ============================================================= -->
  <section class="bg-white pb-20 lg:pb-28">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
      <div class="text-center mb-8">
        <h2 class="text-4xl lg:text-5xl font-bold tracking-tight">Industry</h2>
      </div>

      <!-- Tab buttons -->
      <div class="flex flex-wrap justify-center gap-2 mb-8" role="tablist" aria-label="Industries">
        {industries.map((industry, i) => (
          <button
            type="button"
            role="tab"
            id={`tab-${industry.id}`}
            aria-controls={`panel-${industry.id}`}
            aria-selected={i === 0 ? "true" : "false"}
            data-industry-tab={industry.id}
            class:list={[
              "px-5 py-2 rounded-full text-sm font-medium transition-colors cursor-pointer",
              i === 0 ? "bg-navy text-white" : "bg-black/5 text-ink hover:bg-black/10",
            ]}
          >
            {industry.label}
          </button>
        ))}
      </div>

      <!-- Tab panels -->
      <div class="relative rounded-3xl bg-blue-bg overflow-hidden">
        {industries.map((industry, i) => (
          <div
            id={`panel-${industry.id}`}
            role="tabpanel"
            aria-labelledby={`tab-${industry.id}`}
            data-industry-panel={industry.id}
            class:list={["grid md:grid-cols-2 gap-8 p-8 lg:p-12 items-center", i === 0 ? "" : "hidden"]}
          >
            <div>
              <h3 class="text-3xl lg:text-4xl font-bold tracking-tight">{industry.title}</h3>
              <p class="mt-4 text-ink-muted text-lg leading-relaxed">{industry.body}</p>
              <div class="mt-6">
                <GetDemoButton label="Get a Demo" />
              </div>
            </div>
            <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-white">
              <img src={industry.image} alt="" class="w-full h-full object-cover" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- =============================================================
       BOTTOM CTA — "AI FOR EVERY FUNCTION"
       Blue gradient with dot-pattern overlay (matches Framer).
       ============================================================= -->
  <section class="relative overflow-hidden rounded-3xl mx-6 lg:mx-10 mb-20 lg:mb-28 bg-[linear-gradient(to_bottom,#1281de,#4aa8f5)] py-24 lg:py-32">
    <img
      src="/images/framer/tlIGNlBt0V7x6OXOLl1sY9sjpA.png"
      alt=""
      aria-hidden="true"
      class="absolute inset-x-0 bottom-0 w-full pointer-events-none select-none"
    />
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10 text-center relative z-10">
      <p class="text-sm font-semibold uppercase tracking-wider text-white/80 mb-4">Explore AI for Your Role</p>
      <h2 class="text-4xl lg:text-6xl font-bold text-white tracking-tight">
        AI For Every Function
      </h2>
      <div class="mt-8">
        <GetDemoButton size="lg" label="Get a Demo" />
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  /* =============================================================
     Hero typewriter.
     Cycles through functional roles by typing each letter, holding
     the completed word, then deleting it. A blinking caret sits
     to the right. Respects prefers-reduced-motion by showing the
     first word statically.
     ============================================================= */
  (function typeHeroWord() {
    const textEl = document.getElementById("cycle-word-text");
    if (!textEl) return;
    const words = [
      "Sales", "Finance", "HR", "Marketing",
      "Operations", "Support", "Technology",
      "Legal", "Procurement",
    ];

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      textEl.textContent = words[0];
      return;
    }

    const TYPE_MS   = 85;    // per-letter typing speed
    const DELETE_MS = 45;    // per-letter delete speed
    const HOLD_MS   = 1500;  // pause after full word is typed
    const GAP_MS    = 350;   // pause after deletion before next word

    let wordIndex = 0;
    let charIndex = 0;
    let deleting = false;

    const tick = () => {
      const current = words[wordIndex];
      if (!deleting) {
        charIndex += 1;
        textEl.textContent = current.slice(0, charIndex);
        if (charIndex >= current.length) {
          deleting = true;
          setTimeout(tick, HOLD_MS);
          return;
        }
        setTimeout(tick, TYPE_MS);
      } else {
        charIndex -= 1;
        textEl.textContent = current.slice(0, charIndex);
        if (charIndex <= 0) {
          deleting = false;
          wordIndex = (wordIndex + 1) % words.length;
          setTimeout(tick, GAP_MS);
          return;
        }
        setTimeout(tick, DELETE_MS);
      }
    };
    tick();
  })();

  /* =============================================================
     Hero "Watch Video" modal — opens a native <dialog>, plays the
     self-hosted commercial. Pauses + resets on close.
     ============================================================= */
  (function videoModal() {
    const btn = document.getElementById("hero-watch-video");
    const dlg = document.getElementById("video-modal");
    const closeBtn = document.getElementById("video-modal-close");
    const video = document.getElementById("video-modal-player");
    if (!btn || !dlg || !video) return;
    btn.addEventListener("click", () => {
      dlg.showModal();
      video.currentTime = 0;
      video.play().catch(() => {});
    });
    const close = () => {
      video.pause();
      dlg.close();
    };
    closeBtn?.addEventListener("click", close);
    // Close when clicking the backdrop (outside the video element)
    dlg.addEventListener("click", (e) => {
      if (e.target === dlg) close();
    });
    dlg.addEventListener("cancel", (e) => {
      video.pause();
    });
  })();

  /* =============================================================
     Industry tab switcher — progressive enhancement.
     ============================================================= */
  const tabs   = document.querySelectorAll("[data-industry-tab]");
  const panels = document.querySelectorAll("[data-industry-panel]");
  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const target = tab.getAttribute("data-industry-tab");
      tabs.forEach((t) => {
        const active = t.getAttribute("data-industry-tab") === target;
        t.setAttribute("aria-selected", String(active));
        t.classList.toggle("bg-navy", active);
        t.classList.toggle("text-white", active);
        t.classList.toggle("bg-black/5", !active);
        t.classList.toggle("text-ink", !active);
      });
      panels.forEach((panel) => {
        const match = panel.getAttribute("data-industry-panel") === target;
        panel.classList.toggle("hidden", !match);
      });
    });
  });

</script>
