---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="AskBobAI — Where?"
  description="Empower your teams with a secure and customizable language model solution that seamlessly integrates into your existing tools."
>
  <section class="bg-hero-gradient relative overflow-hidden min-h-[75vh] flex items-center">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10 pt-28 pb-20 text-center relative z-10 w-full">
      <p class="text-[120px] lg:text-[180px] font-bold tracking-tight text-white/90 leading-none">404</p>
      <h2 class="mt-4 text-3xl lg:text-4xl font-semibold text-white">Page not found</h2>
      <p class="mt-4 text-white/80 text-lg max-w-md mx-auto">
        Sorry, we couldn't find the page you're looking for.
      </p>
      <div class="mt-8">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-full bg-white text-ink font-semibold px-7 py-3.5 hover:bg-white/90 transition-colors"
        >
          Go back home
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
