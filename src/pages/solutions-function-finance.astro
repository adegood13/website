---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import FunctionPageBody from "../components/FunctionPageBody.astro";
import Stats from "../components/Stats.astro";
import CTABanner from "../components/CTABanner.astro";
---

<Layout title="AskBobAI — Company" description="AI for finance teams that delivers instant, accurate answers on policies, controls, and audits—improving efficiency, reducing risk, and increasing knowledge usage.">
  <Hero
    eyebrow="Finance Function"
    heading="AskBob: Your Finance Expert."
    subheading="AskBob coordinates specialized agents, tools, and reasoning to solve complex, multi-step business problems."
  />

  <FunctionPageBody
    sampleQuestions={[
      "What is our current balance for all invoices over 90 days overdue?",
      "What is our policy on expense reimbursements?",
      "How much cash do we have on our balance sheet as of March?",
      "What was our last audit opinion?",
    ]}
    coreHeading="Clarity, consistency, and confidence—powered by your source of truth."
    coreBody="AskBob helps finance teams answer complex questions about policies, controls, contracts, and procedures using your actual documents. No spreadsheets needed."
    coreImage="/images/framer/ECE0bA2p5cyrY6700hOzN45vkzg.jpg"
    coreImageAlt="A person on a phone call pointing a pen at a financial document"
    helpsWith={[
      "Interpreting accounting policies and controls",
      "Supporting audits and compliance reviews",
      "Explaining processes to non-finance teams",
      "Reducing dependency on a few subject-matter experts",
    ]}
    whyChooseHeading="Why Finance Teams Choose AskBob"
    whyChoose={[
      "Every answer includes a citation",
      "Reduces risk from outdated or informal guidance",
      "Keeps sensitive data governed and secure",
      "Improves response time without sacrificing accuracy",
    ]}
    whyImage="/images/framer/SPF5YR2LOvndnaUmUaAN5TOFwg.png"
    whyImageAlt="Two professionals in a modern office analyzing financial data"
  />

  <Stats />

  <CTABanner
    heading="Get your Finance Function Started Today!"
    subheading="Experience the power of function-specific language models firsthand! Kickstart your journey towards enhanced efficiency and precision by scheduling a demo tailored to your function."
  />
</Layout>
