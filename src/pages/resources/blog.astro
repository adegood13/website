---
import Layout from "../../layouts/Layout.astro";
import CTABanner from "../../components/CTABanner.astro";

/* Blog data model. Each post is a standalone object here so adding a new
   post is just appending to this array. When a headless CMS is added later,
   swap this array for a CMS query (Contentful/Sanity/Markdown in /content). */
const posts = [
  {
    slug: "local-government-health-initiatives",
    title: "10 Local Government Health Initiatives",
    excerpt: "Discover 10 proven local government health initiatives to improve community wellness, reduce costs, and create healthier cities through smarter public initiatives.",
    category: "Government",
    image: "/images/framer-assets/AsMW1VzrUfw5ibdSYkRCtbruoI.jpg",
    date: "Apr 2026",
  },
  {
    slug: "what-is-a-cdp",
    title: "What Is a CDP? Customer Data Platform Guide for 2026",
    excerpt: "Learn what a Customer Data Platform (CDP) is, how it works, why it matters in 2026, CDP vs CRM comparisons, AI use cases, and how to choose the right platform.",
    category: "Data",
    image: "/images/framer-assets/18BKTqIanfYbJ58eMQ1qw2laOI.png",
    date: "Mar 2026",
  },
  {
    slug: "ai-for-loan-officers",
    title: "AI for Loan Officers: From Application Takers to Deal Makers",
    excerpt: "AI helps loan officers answer borrower questions instantly, structure better deals, and close more loans by turning fragmented guidelines into real-time insights.",
    category: "Mortgage",
    image: "/images/framer-assets/KsxgV5O5hTWKGFOQVDy4vlY1f6o.jpg",
    date: "Mar 2026",
  },
  {
    slug: "underwriting-barriers",
    title: "Common Underwriting Barriers — and How Teams Overcome Them",
    excerpt: "Common mortgage underwriting barriers—and how lenders overcome them. Learn what causes delays, how teams reduce risk, and how smarter workflows and AI help.",
    category: "Mortgage",
    image: "/images/framer-assets/ECE0bA2p5cyrY6700hOzN45vkzg.jpg",
    date: "Feb 2026",
  },
  {
    slug: "ai-in-local-government",
    title: "AI in Local Government",
    excerpt: "Discover 10 real-world use cases helping cities do more with less.",
    category: "Government",
    image: "/images/framer-assets/BxozmlnFLDGrw5NRPeBG0zjTw.jpg",
    date: "Feb 2026",
  },
  {
    slug: "fastest-brands-retail-2026",
    title: "Fastest Brands to Watch in Retail in 2026",
    excerpt: "Discover the fastest-growing retail brands of 2026 and the trends driving them—protein, convenience, and better-for-you products shaping the future.",
    category: "Retail",
    image: "/images/framer-assets/iHfhKUde9yPc58XdS4hbyseIWI.jpg",
    date: "Jan 2026",
  },
];
---

<Layout title="AskBobAI — Blog" description="Read AskBobAI blog articles on AI, automation, and productivity—built for teams using knowledge to move faster.">
  <!-- Header -->
  <section class="bg-white pt-20 pb-12">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10 text-center">
      <p class="text-sm font-semibold text-brand uppercase tracking-wider mb-3">Resources</p>
      <h1 class="text-4xl lg:text-6xl font-bold tracking-tight">Blog</h1>
      <p class="mt-4 text-ink-muted text-lg max-w-2xl mx-auto">
        Ideas, playbooks, and trends from the AskBobAI team.
      </p>
    </div>
  </section>

  <!-- Card grid -->
  <section class="bg-white pb-20">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map(post => (
        <a href={`/resources/blog/${post.slug}`} class="group block rounded-2xl overflow-hidden border border-black/5 hover:shadow-card transition-shadow bg-white">
          <div class="aspect-[16/10] overflow-hidden bg-blue-bg">
            <img src={post.image} alt="" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-6">
            <div class="flex items-center gap-2 text-xs text-ink-muted mb-3">
              <span class="bg-brand-bg text-brand-dark px-2 py-0.5 rounded-full font-semibold">{post.category}</span>
              <span>·</span>
              <span>{post.date}</span>
            </div>
            <h2 class="text-xl font-bold leading-tight group-hover:text-brand transition-colors">{post.title}</h2>
            <p class="mt-3 text-sm text-ink-muted leading-relaxed">{post.excerpt}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <CTABanner heading="Get Started Today!" ctaLabel="Schedule Demo" />
</Layout>
