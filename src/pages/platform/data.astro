---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import FeatureSplit from "../../components/FeatureSplit.astro";
import Stats from "../../components/Stats.astro";
import CTABanner from "../../components/CTABanner.astro";
---

<Layout title="AskBobAI — Platform — Data" description="AskBobAI connects to your data sources to deliver real-time insights, answers, and automation across your business.">
  <Hero
    eyebrow="Data is Power"
    heading="AskBob delivers instant, trusted answers via your internal data"
    subheading="Improving customer service while keeping employees confident, supported, and focused."
  />

  <FeatureSplit
    heading="AI only works when people use the data."
    body="The right data powers better decisions delivered directly into everyday workflows."
    image="/images/framer-assets/SPF5YR2LOvndnaUmUaAN5TOFwg.png"
    imageAlt="Data visualization"
    background="white"
  />

  <FeatureSplit
    heading="Data is Context, Not Everything"
    body="Successful AI isn't powered by all your data. It's powered by the right subset—trusted, relevant, and purpose-built. AskBob works with purposeful data:"
    bullets={[
      "Knowledge articles",
      "Compliance materials",
      "Product documentation",
      "Policy guides",
      "Customer case histories",
      "Internal FAQs",
    ]}
    image="/images/framer-assets/k45eD1b4A1P0f5cPmUjFeSnGOVU.png"
    imageAlt="Data scope illustration"
    background="blue"
    reversed
    ctaLabel="Get a Demo"
  />

  <!-- Integrations row -->
  <section class="bg-white py-20 lg:py-24">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold tracking-tight">Designed For <span class="text-brand">In-Workflow AI Delivery</span></h2>
      <p class="mt-4 text-ink-muted text-lg max-w-2xl mx-auto">
        AskBob operates inside the tools your teams already use — ensuring consistent answers without disruption.
      </p>
      <div class="mt-12 flex flex-wrap items-center justify-center gap-8">
        {[
          "zendesk-dark", "confluence", "chrome-extensions",
          "docusaurus", "gmail", "salesforce",
        ].map(id => (
          <div class="w-32 h-16 flex items-center justify-center">
            <img src={`/images/integrations/${id}.png`} alt="" class="max-h-10 w-auto object-contain opacity-80" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <FeatureSplit
    heading="Data Precision Over Data Sprawl"
    body="AskBob is built for precision, not data sprawl. By using scoped, source-attributed knowledge, teams get faster answers, stronger trust, and easier governance."
    bullets={[
      "Fast Answers — instant responses pulled from scoped knowledge",
      "Lower Risk, Built-In Governance — role-appropriate data access",
      "Trusted by Design — curated, approved, source-attributed",
    ]}
    image="/images/framer-assets/k45eD1b4A1P0f5cPmUjFeSnGOVU.png"
    imageAlt="Data precision illustration"
    background="blue"
  />

  <Stats />

  <CTABanner
    heading="Get Started Today!"
    subheading="Experience the power of function-specific AI Agents firsthand by scheduling a demo tailored to your sector."
    ctaLabel="Schedule Demo"
  />
</Layout>
