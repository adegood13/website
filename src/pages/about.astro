---
/**
 * About page — pixel-perfect port of askbobai.com/about.
 * All copy, imagery, and bios pulled from the live site.
 */
import Layout from "../layouts/Layout.astro";
import CTABanner from "../components/CTABanner.astro";

/* Hero chat bubbles — exact images from askbobai.com. */
const heroChat = [
  {
    avatar: "/images/framer/9yCODFjCQVcckbyy3PRxeRvmDw.png",
    text: "Can you describe the residual income method for evaluating borrower affordability under FHLMC standards?",
  },
  {
    avatar: "/images/framer/ggA8oK3DnI1jLkSLw5IE6PEzfs.png",
    text: "How does FNMA instruct underwriters to treat assets held in cryptocurrencies when considering them for down payment funds?",
  },
  {
    avatar: "/images/framer/HumogXbWXkFa5cnEb891PqoA1Mo.png",
    text: "What documentation is required to verify large deposits found during the bank statement review process under FNMA rules?",
  },
];

/* Bios pulled verbatim from askbobai.com/about (the "Read More" expansion). */
const leadership = [
  {
    name: "Andrew DeGood",
    role: "CEO & Co-Founder",
    photo: "/images/framer/iHfhKUde9yPc58XdS4hbyseIWI.jpg",
    linkedin: "https://www.linkedin.com/in/andrewdegood/",
    bio: "Andrew DeGood has established himself as a seasoned leader in the industry. Serving as a founder and C-suite executive, he has successfully navigated various challenges and triumphs, shaping his expertise along the way. Throughout his illustrious career, Andrew has demonstrated his ability to lead organizations of all sizes, from startups to Fortune 500 companies, with a focus on overseeing operations, product development, and client service. His approach is rooted in a comprehensive understanding of business dynamics, emphasizing strategic growth, innovation, and the fostering of healthy workplace cultures. Andrew is deeply committed to creating supportive environments that facilitate sustainable success. Furthermore, he is a passionate advocate for mental health and effective communication, leveraging his skills to guide companies through industry challenges.",
  },
  {
    name: "Tim Nguyen",
    role: "CTO & Co-founder",
    photo: "/images/framer/KsxgV5O5hTWKGFOQVDy4vlY1f6o.jpg",
    linkedin: "https://www.linkedin.com/in/timnguyenbsm/",
    bio: "Tim Nguyen is the visionary force behind BeSmartee, a groundbreaking fintech enterprise revolutionizing the mortgage and commercial lending sectors. As CEO and Co-Founder, Tim drives the company's strategic vision, product innovation, and cultural ethos. With a knack for pioneering solutions, he spearheads mergers & acquisitions and cultivates strong partnerships with clients and stakeholders. Tim's entrepreneurial journey began in high school, where he cultivated self-taught coding skills and launched multiple online ventures. Since then, he's lent his expertise to local businesses across revenue spectrums, from $5 million to $100 million annually, while also investing in startups to fuel innovation. Beyond business, Tim cherishes time with family, indulges in creative pursuits like writing and music, and enjoys diverse interests including farming, poker, baseball, MMA, and basketball.",
  },
];

const values = [
  { title: "Have Fun",           body: "We infuse every project with a sense of joy and excitement, harnessing the power of fun to drive creativity and innovation." },
  { title: "Be Transparent",     body: "We believe in open and honest communication, both internally within our team and externally with our clients and partners." },
  { title: "Embrace Diversity",  body: "By embracing different perspectives, backgrounds, and experiences, we create a more dynamic work environment." },
  { title: "Act with Integrity", body: "Integrity is at the core of everything we do. Integrity guides us in every decision we make, ensuring we build trust." },
];
---

<Layout
  title="AskBobAI — Company"
  description="Learn about AskBobAI's mission to make company knowledge useful—helping teams save time, reduce cost, and move faster."
>
  <!-- HERO ================================================================= -->
  <section class="bg-hero-gradient relative overflow-hidden pt-28 lg:pt-36">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10 pt-12 pb-24 lg:pt-16 lg:pb-32 text-center relative z-10">
      <h1 class="text-white font-semibold tracking-tight text-4xl sm:text-5xl lg:text-[54px] leading-[1.1] max-w-3xl mx-auto">
        Meet the Diverse Minds<br/>Fueling AskBob's Innovation!
      </h1>

      <!-- Floating chat bubbles: 3 user Q's + 1 Ask Bob response.
           Desktop: scattered at different columns. Mobile: stacked. -->
      <div class="mt-12 max-w-5xl mx-auto text-left">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-y-3">
          <!-- User bubble 1 -->
          <div class="md:col-span-5 md:col-start-1">
            <div class="bg-white/95 rounded-2xl p-4 shadow-lg flex items-start gap-3">
              <img src={heroChat[0].avatar} alt="" class="w-8 h-8 rounded-full shrink-0 object-cover" />
              <p class="text-sm leading-relaxed text-ink">{heroChat[0].text}</p>
            </div>
          </div>

          <!-- Ask Bob response -->
          <div class="md:col-span-5 md:col-start-8">
            <div class="bg-[#1281DE] rounded-2xl p-4 shadow-lg flex items-center gap-3 text-white">
              <img
                src="/images/framer/nH9dzkavs8IwOFM2h6rHi9yEcmA.svg"
                alt=""
                class="w-8 h-8 shrink-0"
              />
              <p class="text-sm font-medium">How can I help?</p>
            </div>
          </div>

          <!-- User bubble 2 (center) -->
          <div class="md:col-span-5 md:col-start-4">
            <div class="bg-white/95 rounded-2xl p-4 shadow-lg flex items-start gap-3">
              <img src={heroChat[1].avatar} alt="" class="w-8 h-8 rounded-full shrink-0 object-cover" />
              <p class="text-sm leading-relaxed text-ink">{heroChat[1].text}</p>
            </div>
          </div>

          <!-- User bubble 3 (right) -->
          <div class="md:col-span-5 md:col-start-7">
            <div class="bg-white/95 rounded-2xl p-4 shadow-lg flex items-start gap-3">
              <img src={heroChat[2].avatar} alt="" class="w-8 h-8 rounded-full shrink-0 object-cover" />
              <p class="text-sm leading-relaxed text-ink">{heroChat[2].text}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MEET THE TEAM ========================================================= -->
  <section class="bg-white py-20 lg:py-28">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <h2 class="text-4xl lg:text-5xl font-bold tracking-tight">Meet the Team.</h2>
        <p class="mt-3 text-ink-muted">The leadership team charting the course.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {leadership.map((person, i) => (
          <details class="group rounded-3xl overflow-hidden bg-white border border-black/5 shadow-sm" data-bio-card={i}>
            <summary class="cursor-pointer list-none">
              <div class="aspect-[5/4] overflow-hidden bg-blue-bg">
                <img src={person.photo} alt={person.name} class="w-full h-full object-cover" />
              </div>
              <div class="p-6 flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-xl font-bold">{person.name}</h3>
                  <p class="text-sm text-ink-muted mt-0.5">{person.role}</p>
                </div>
                <a
                  href={person.linkedin}
                  target="_blank"
                  rel="noopener"
                  aria-label={`${person.name} on LinkedIn`}
                  class="shrink-0 w-8 h-8 inline-flex items-center justify-center rounded-md bg-ink text-white hover:bg-brand transition-colors"
                  onclick="event.stopPropagation()"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.05-1.86-3.05-1.86 0-2.15 1.45-2.15 2.95v5.67H9.35V9h3.41v1.56h.05c.47-.9 1.63-1.86 3.36-1.86 3.6 0 4.27 2.37 4.27 5.46v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.8 0 0 .77 0 1.72v20.56C0 23.23.8 24 1.77 24h20.45C23.2 24 24 23.23 24 22.28V1.72C24 .77 23.2 0 22.22 0z"/>
                  </svg>
                </a>
              </div>
              <p class="px-6 pb-6 text-sm font-semibold text-brand inline-flex items-center gap-1 group-open:hidden">
                Read More
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
              </p>
            </summary>
            <div class="px-6 pb-6">
              <p class="text-ink-muted leading-relaxed text-sm">{person.bio}</p>
              <p class="mt-5 text-sm font-semibold text-brand inline-flex items-center gap-1">
                Close
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 15l-6-6-6 6"/></svg>
              </p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ENVISIONING =========================================================== -->
  <section class="bg-white pb-16 lg:pb-24">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10 grid md:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div>
        <h2 class="text-3xl lg:text-[40px] font-bold tracking-tight leading-tight">
          Envisioning: The New Personalized AI for Business.
        </h2>
        <p class="mt-6 text-ink-muted leading-relaxed">
          At AskBob AI, we're driven by a shared passion for ushering in a future where
          businesses flourish through the transformative capabilities of artificial intelligence.
          Our mission is to spearhead this evolution by providing cutting-edge AI solutions
          meticulously crafted to cater to the unique requirements of each business.
          We firmly believe in simplifying the process of AI integration, empowering
          organizations to amplify their efficiency, productivity, and innovation effortlessly.
          With our personalized approach, we guarantee that businesses experience tangible
          and measurable outcomes, enabling them to thrive in today's dynamic landscape.
          Join us on our journey as we redefine the possibilities of AI and revolutionize
          the way businesses operate to succeed.
        </p>
      </div>
      <div class="rounded-3xl overflow-hidden bg-blue-bg aspect-[4/3]">
        <img src="/images/framer/5eeCkWc4COAcouOQujsWMCTW5U.jpg" alt="" class="w-full h-full object-cover" />
      </div>
    </div>
  </section>

  <!-- JOURNEY (reversed) ===================================================== -->
  <section class="bg-white pb-16 lg:pb-24">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10 grid md:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div class="rounded-3xl overflow-hidden bg-blue-bg aspect-[4/3] md:order-first">
        <img src="/images/framer/E9MTUnM4A8CNwMKe5enPRSuxUIQ.jpg" alt="" class="w-full h-full object-cover" />
      </div>
      <div>
        <h2 class="text-3xl lg:text-[40px] font-bold tracking-tight leading-tight">
          The Journey of AskBob's Founders.
        </h2>
        <p class="mt-6 text-ink-muted leading-relaxed">
          Tim Nguyen and Andrew DeGood, the co-founders of AskBob AI, forged a dynamic
          partnership rooted in their shared values and diverse expertise. Tim's formative
          years amidst the turmoil of war and poverty instilled within him a profound
          dedication to driving societal change through entrepreneurial endeavors. Conversely,
          Andrew's extensive background in finance and technology imbued him with a deep-seated
          passion for innovation and the promotion of workplace well-being. United by a shared
          vision to harness the potential of artificial intelligence for positive societal impact,
          they embarked on a journey to establish AskBob AI. Combining Tim's entrepreneurial
          drive with Andrew's strategic acumen, they laid the foundation for a groundbreaking
          venture that stands today as a beacon of innovation and progress.
        </p>
      </div>
    </div>
  </section>

  <!-- WHAT WE VALUE ========================================================= -->
  <section class="bg-white pb-20 lg:pb-28">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl lg:text-[40px] font-bold tracking-tight">What We Value.</h2>
        <p class="mt-6 text-ink-muted leading-relaxed">
          At AskBob AI, we live and breathe our core values, infusing every aspect of our work
          with joy, honesty, pioneering spirit, and genuine authenticity. Every day, we tackle
          challenges head-on, seeing them as opportunities for innovation and growth. We're all
          about giving back, sharing our expertise, resources, and time to uplift our team,
          clients, and community. With a relentless pursuit of excellence, we pour our hearts
          into crafting exceptional solutions and experiences that go above and beyond
          expectations. These values drive us forward, fueling our quest for greatness and
          our mission to make a meaningful impact in the realm of AI technology.
        </p>
      </div>
      <!-- Team illustration above the value cards -->
      <div class="rounded-3xl overflow-hidden aspect-[21/9] mb-10">
        <img src="/images/framer/DlKrC2goPf3qUYZuksfCiltPks.jpg" alt="The AskBobAI team collaborating" class="w-full h-full object-cover" />
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {values.map(v => (
          <div class="bg-blue-bg rounded-2xl p-6 text-center">
            <h3 class="font-bold text-lg">{v.title}</h3>
            <p class="mt-3 text-sm text-ink-muted leading-relaxed">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Get Started Today!"
    subheading="Experience the power of function-specific AI Agents firsthand! Kickstart your journey towards enhanced efficiency and precision by scheduling a demo tailored to your sector."
  />
</Layout>
