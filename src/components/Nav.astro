---
/**
 * Top navigation — matches askbobai.com exactly.
 *
 * Renders as a single floating white pill, fixed 8px from the viewport top,
 * centered with a max-width. Dark ink text at every scroll position (no
 * transparent-over-hero transition).
 *
 * Scroll behavior: the pill hides when the user scrolls down and returns as
 * soon as they scroll up. Implemented via the `.nav-pill--hidden` class,
 * whose CSS lives in the scoped <style> block below.
 */
import GetDemoButton from "./GetDemoButton.astro";

/* URL slugs match askbobai.com exactly: flat routes, no hyphens in
   multi-word function slugs (humanresources, supplychain). */
const solutions = [
  { heading: "By Function", links: [
    { href: "/solutions-function-technology",      label: "Technology" },
    { href: "/solutions-function-finance",         label: "Finance" },
    { href: "/solutions-function-humanresources", label: "Human Resources" },
    { href: "/solutions-function-sales",           label: "Sales" },
    { href: "/solutions-function-supplychain",    label: "Supply Chain" },
    { href: "/solutions-function-support",         label: "Support" },
  ]},
  { heading: "By Industry", links: [
    { href: "/solutions-byindustry-finance",    label: "Banking" },
    { href: "/solutions-byindustry-mortgage",   label: "Mortgage" },
    { href: "/solutions-byindustry-insurance",  label: "Insurance" },
    { href: "/solutions-byindustry-government", label: "Government" },
    { href: "/solutions-byindustry-retail",     label: "Retail" },
    { href: "/solutions-byindustry-saas",       label: "SaaS" },
  ]},
];

const platform = [
  { href: "/platform-data",          label: "Data" },
  { href: "/platform-knowledge",     label: "Knowledge" },
  { href: "/platform-workflows",     label: "Workflows" },
  { href: "/platform-orchestration", label: "Orchestration" },
];

const resources = [
  { href: "/resources-blog",   label: "Blog" },
  { href: "/resources-guides", label: "Guides" },
];
---

<!--
  Nav rebuilt to match askbobai.com exactly:
  - Always a white pill, never transparent over the hero
  - position: fixed, 8px from viewport top, centered with a max-width
  - border-radius: 32px, height 64px, subtle 24px/12px side padding
  - Dark ink text at all scroll positions (no scroll-state transition)
  - Top-level items: Solutions ▾, Platform ▾, AI Agents, Resources ▾, About
  - Right side: Get a Demo (green pill)
-->
<header
  id="site-nav"
  class="fixed left-0 right-0 z-50 px-2 lg:px-4 pointer-events-none nav-pill"
>
  <div class="max-w-[1200px] mx-auto bg-white rounded-full h-16 pl-6 pr-3 flex items-center justify-between gap-4 pointer-events-auto">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0" aria-label="AskBobAI home">
      <span class="text-xl font-bold tracking-tight text-ink">AskBobAI</span>
      <img src="/images/askbobai-logo.svg" alt="" class="h-5 w-auto" />
    </a>

    <!-- Desktop menu -->
    <nav class="hidden lg:flex items-center gap-1 text-[15px] font-medium text-ink" aria-label="Primary">
      <div class="relative group">
        <button class="px-4 py-2 rounded-md hover:bg-black/5 flex items-center gap-1 cursor-pointer">
          Solutions
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="opacity-70">
            <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 w-[480px]">
          <div class="grid grid-cols-2 gap-6 p-6 bg-white text-ink rounded-xl shadow-xl border border-black/5">
            {solutions.map(group => (
              <div>
                <p class="text-xs uppercase tracking-wider text-ink-muted mb-3 font-semibold">{group.heading}</p>
                <ul class="space-y-2">
                  {group.links.map(l => (
                    <li><a href={l.href} class="block py-1 hover:text-brand transition-colors">{l.label}</a></li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="relative group">
        <button class="px-4 py-2 rounded-md hover:bg-black/5 flex items-center gap-1 cursor-pointer">
          Platform
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="opacity-70">
            <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 w-[220px]">
          <ul class="p-4 bg-white text-ink rounded-xl shadow-xl border border-black/5 space-y-1">
            {platform.map(l => (
              <li><a href={l.href} class="block px-3 py-2 rounded hover:bg-black/5 hover:text-brand transition-colors">{l.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <a href="/ai-agents" class="px-4 py-2 rounded-md hover:bg-black/5">AI Agents</a>

      <div class="relative group">
        <button class="px-4 py-2 rounded-md hover:bg-black/5 flex items-center gap-1 cursor-pointer">
          Resources
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="opacity-70">
            <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 w-[180px]">
          <ul class="p-4 bg-white text-ink rounded-xl shadow-xl border border-black/5 space-y-1">
            {resources.map(l => (
              <li><a href={l.href} class="block px-3 py-2 rounded hover:bg-black/5 hover:text-brand transition-colors">{l.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <a href="/about" class="px-4 py-2 rounded-md hover:bg-black/5">About</a>
    </nav>

    <!-- Get a Demo pill (desktop) + mobile toggle -->
    <div class="flex items-center gap-2 shrink-0">
      <a
        href="/get-a-demo"
        class="hidden lg:inline-flex items-center gap-2 rounded-full bg-brand px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-light transition-colors"
      >
        Get a Demo
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      <button
        id="nav-toggle"
        class="lg:hidden p-2 -mr-1 text-ink"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer — sits below the pill, same horizontal margin -->
  <div id="mobile-nav" class="lg:hidden hidden max-w-[1200px] mx-auto mt-2 bg-white text-ink rounded-2xl shadow-xl pointer-events-auto">
    <div class="px-6 py-4 space-y-3 text-base font-medium">
      <details class="group">
        <summary class="flex justify-between items-center cursor-pointer py-2 list-none">
          Solutions
          <span class="group-open:rotate-180 transition-transform">▾</span>
        </summary>
        <div class="pl-4 py-2 space-y-3">
          {solutions.map(group => (
            <div>
              <p class="text-xs uppercase text-ink-muted font-semibold mb-1">{group.heading}</p>
              <ul class="space-y-1">
                {group.links.map(l => <li><a href={l.href} class="block py-1">{l.label}</a></li>)}
              </ul>
            </div>
          ))}
        </div>
      </details>
      <details class="group">
        <summary class="flex justify-between items-center cursor-pointer py-2 list-none">
          Platform <span class="group-open:rotate-180 transition-transform">▾</span>
        </summary>
        <ul class="pl-4 py-2 space-y-1">
          {platform.map(l => <li><a href={l.href} class="block py-1">{l.label}</a></li>)}
        </ul>
      </details>
      <a href="/ai-agents" class="block py-2">AI Agents</a>
      <details class="group">
        <summary class="flex justify-between items-center cursor-pointer py-2 list-none">
          Resources <span class="group-open:rotate-180 transition-transform">▾</span>
        </summary>
        <ul class="pl-4 py-2 space-y-1">
          {resources.map(l => <li><a href={l.href} class="block py-1">{l.label}</a></li>)}
        </ul>
      </details>
      <a href="/about" class="block py-2">About</a>
      <div class="pt-2"><GetDemoButton /></div>
    </div>
  </div>
</header>

<script is:inline>
  /* Hide-on-scroll-down / show-on-scroll-up.
     Always visible at the very top; slides up off-screen when scrolling
     down past a short threshold; slides back in on any upward scroll.
     Respects prefers-reduced-motion by keeping the nav always visible. */
  (function navScroll() {
    const nav = document.getElementById("site-nav");
    if (!nav) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const DELTA = 6;           // ignore tiny jitter
    const TOP_SAFE = 80;       // always show this close to the top
    let lastY = window.scrollY;
    let ticking = false;

    const update = () => {
      const y = window.scrollY;
      const diff = y - lastY;
      if (Math.abs(diff) < DELTA) { ticking = false; return; }
      if (y < TOP_SAFE || diff < 0) nav.classList.remove("nav-pill--hidden");
      else nav.classList.add("nav-pill--hidden");
      lastY = y;
      ticking = false;
    };

    window.addEventListener("scroll", () => {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }, { passive: true });
  })();

  /* Mobile drawer toggle + close-on-link-click. */
  (function mobileDrawer() {
    const btn = document.getElementById("nav-toggle");
    const drawer = document.getElementById("mobile-nav");
    if (!btn || !drawer) return;
    btn.addEventListener("click", () => {
      const open = drawer.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", String(open));
    });
    /* Close the drawer when a link is tapped so the next page doesn't
       render with the drawer still open. */
    drawer.querySelectorAll("a").forEach(a => {
      a.addEventListener("click", () => {
        drawer.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
      });
    });
  })();
</script>

<style>
  /* Explicit base (without modifier) + explicit modifier, so the modifier
     has strictly higher specificity than the base and can't lose to
     cascade-order ambiguity in the bundled output. */
  .nav-pill:not(.nav-pill--hidden) {
    top: 0.5rem;
    opacity: 1;
  }
  .nav-pill {
    transition: top 300ms ease-out, opacity 300ms ease-out;
  }
  .nav-pill.nav-pill--hidden {
    top: -96px;
    opacity: 0;
    pointer-events: none;
  }
</style>
