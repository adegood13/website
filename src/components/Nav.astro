---
/**
 * Top navigation — matches askbobai.com behavior in three states:
 *
 *   1. AT TOP (y < ~80)
 *      Transparent — white logo + white nav links floating directly over
 *      the blue hero gradient. "Get a Demo" renders as a white-outlined
 *      pill instead of a solid-green one.
 *
 *   2. SCROLLING UP (below top)
 *      Slides into view as a white rounded pill centered at the top.
 *      Dark ink text, solid-green "Get a Demo" button.
 *
 *   3. SCROLLING DOWN (below top)
 *      Slides up off-screen (translate-y + opacity 0).
 *
 * State machine lives in the inline script. Visual appearance swaps via
 * two modifier classes on #site-nav: `.nav-pill--transparent` and
 * `.nav-pill--hidden`.
 */
import GetDemoButton from "./GetDemoButton.astro";

const solutions = [
  { heading: "By Function", links: [
    { href: "/solutions-function-technology",      label: "Technology" },
    { href: "/solutions-function-finance",         label: "Finance" },
    { href: "/solutions-function-humanresources", label: "Human Resources" },
    { href: "/solutions-function-sales",           label: "Sales" },
    { href: "/solutions-function-supplychain",    label: "Supply Chain" },
    { href: "/solutions-function-support",         label: "Support" },
  ]},
  { heading: "By Industry", links: [
    { href: "/solutions-byindustry-finance",    label: "Banking" },
    { href: "/solutions-byindustry-mortgage",   label: "Mortgage" },
    { href: "/solutions-byindustry-insurance",  label: "Insurance" },
    { href: "/solutions-byindustry-government", label: "Government" },
    { href: "/solutions-byindustry-retail",     label: "Retail" },
    { href: "/solutions-byindustry-saas",       label: "SaaS" },
  ]},
];

const platform = [
  { href: "/platform-data",          label: "Data" },
  { href: "/platform-knowledge",     label: "Knowledge" },
  { href: "/platform-workflows",     label: "Workflows" },
  { href: "/platform-orchestration", label: "Orchestration" },
];

const resources = [
  { href: "/resources-blog",   label: "Blog" },
  { href: "/resources-guides", label: "Guides" },
];
---

<!--
  Nav starts in the `.nav-pill--transparent` state for pages that open at
  the top of a blue hero. The inline script toggles classes on scroll.
-->
<header
  id="site-nav"
  class="nav-pill nav-pill--transparent fixed left-0 right-0 z-50 px-2 lg:px-4 pointer-events-none"
>
  <div class="nav-pill-bg max-w-[1200px] mx-auto rounded-full h-16 pl-6 pr-3 flex items-center justify-between gap-4 pointer-events-auto">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0" aria-label="AskBobAI home">
      <span class="nav-text text-xl font-bold tracking-tight">AskBobAI</span>
      <img src="/images/askbobai-logo.svg" alt="" class="h-5 w-auto" />
    </a>

    <!-- Desktop menu -->
    <nav class="nav-text hidden lg:flex items-center gap-1 text-[15px] font-medium" aria-label="Primary">
      <div class="relative group">
        <button class="nav-text-hover px-4 py-2 rounded-md flex items-center gap-1 cursor-pointer">
          Solutions
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="opacity-70">
            <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 w-[480px]">
          <div class="grid grid-cols-2 gap-6 p-6 bg-white text-ink rounded-xl shadow-xl border border-black/5">
            {solutions.map(group => (
              <div>
                <p class="text-xs uppercase tracking-wider text-ink-muted mb-3 font-semibold">{group.heading}</p>
                <ul class="space-y-2">
                  {group.links.map(l => (
                    <li><a href={l.href} class="block py-1 hover:text-brand transition-colors">{l.label}</a></li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="relative group">
        <button class="nav-text-hover px-4 py-2 rounded-md flex items-center gap-1 cursor-pointer">
          Platform
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="opacity-70">
            <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 w-[220px]">
          <ul class="p-4 bg-white text-ink rounded-xl shadow-xl border border-black/5 space-y-1">
            {platform.map(l => (
              <li><a href={l.href} class="block px-3 py-2 rounded hover:bg-black/5 hover:text-brand transition-colors">{l.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <a href="/ai-agents" class="nav-text-hover px-4 py-2 rounded-md">AI Agents</a>

      <div class="relative group">
        <button class="nav-text-hover px-4 py-2 rounded-md flex items-center gap-1 cursor-pointer">
          Resources
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="opacity-70">
            <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 w-[180px]">
          <ul class="p-4 bg-white text-ink rounded-xl shadow-xl border border-black/5 space-y-1">
            {resources.map(l => (
              <li><a href={l.href} class="block px-3 py-2 rounded hover:bg-black/5 hover:text-brand transition-colors">{l.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <a href="/about" class="nav-text-hover px-4 py-2 rounded-md">About</a>
    </nav>

    <!-- Get a Demo pill (desktop) + mobile toggle -->
    <div class="flex items-center gap-2 shrink-0">
      <a
        href="/get-a-demo"
        class="nav-cta hidden lg:inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold transition-colors"
      >
        Get a Demo
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      <button
        id="nav-toggle"
        class="nav-text lg:hidden p-2 -mr-1"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer — sits below the pill, same horizontal margin -->
  <div id="mobile-nav" class="lg:hidden hidden max-w-[1200px] mx-auto mt-2 bg-white text-ink rounded-2xl shadow-xl pointer-events-auto">
    <div class="px-6 py-4 space-y-3 text-base font-medium">
      <details class="group">
        <summary class="flex justify-between items-center cursor-pointer py-2 list-none">
          Solutions
          <span class="group-open:rotate-180 transition-transform">▾</span>
        </summary>
        <div class="pl-4 py-2 space-y-3">
          {solutions.map(group => (
            <div>
              <p class="text-xs uppercase text-ink-muted font-semibold mb-1">{group.heading}</p>
              <ul class="space-y-1">
                {group.links.map(l => <li><a href={l.href} class="block py-1">{l.label}</a></li>)}
              </ul>
            </div>
          ))}
        </div>
      </details>
      <details class="group">
        <summary class="flex justify-between items-center cursor-pointer py-2 list-none">
          Platform <span class="group-open:rotate-180 transition-transform">▾</span>
        </summary>
        <ul class="pl-4 py-2 space-y-1">
          {platform.map(l => <li><a href={l.href} class="block py-1">{l.label}</a></li>)}
        </ul>
      </details>
      <a href="/ai-agents" class="block py-2">AI Agents</a>
      <details class="group">
        <summary class="flex justify-between items-center cursor-pointer py-2 list-none">
          Resources <span class="group-open:rotate-180 transition-transform">▾</span>
        </summary>
        <ul class="pl-4 py-2 space-y-1">
          {resources.map(l => <li><a href={l.href} class="block py-1">{l.label}</a></li>)}
        </ul>
      </details>
      <a href="/about" class="block py-2">About</a>
      <div class="pt-2"><GetDemoButton /></div>
    </div>
  </div>
</header>

<script is:inline>
  /* Three-state nav controller:
     - At top (scrollY < TOP_SAFE):        `.nav-pill--transparent`
     - Scrolling up below top:             no modifier (pill visible)
     - Scrolling down below top:           `.nav-pill--hidden`
     Respects `prefers-reduced-motion` by skipping the listener and
     leaving the server-rendered transparent state in place. */
  (function navScroll() {
    const nav = document.getElementById("site-nav");
    if (!nav) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const DELTA = 6;          // ignore tiny jitter
    const TOP_SAFE = 80;      // considered "at top" within this margin
    let lastY = window.scrollY;
    let ticking = false;

    const apply = (y, diff) => {
      // Case A: within the top-safe band → transparent variant
      if (y < TOP_SAFE) {
        nav.classList.add("nav-pill--transparent");
        nav.classList.remove("nav-pill--hidden");
        return;
      }
      nav.classList.remove("nav-pill--transparent");
      // Case B: scrolling up → show the pill
      if (diff < 0) {
        nav.classList.remove("nav-pill--hidden");
        return;
      }
      // Case C: scrolling down → hide
      nav.classList.add("nav-pill--hidden");
    };

    const update = () => {
      const y = window.scrollY;
      const diff = y - lastY;
      if (Math.abs(diff) < DELTA && y > TOP_SAFE) { ticking = false; return; }
      apply(y, diff);
      lastY = y;
      ticking = false;
    };
    /* Prime the state immediately so first paint matches the current
       scroll position (SSR assumes we're at the top). */
    apply(window.scrollY, 0);

    window.addEventListener("scroll", () => {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }, { passive: true });
  })();

  /* Mobile drawer toggle + close-on-link-click. */
  (function mobileDrawer() {
    const btn = document.getElementById("nav-toggle");
    const drawer = document.getElementById("mobile-nav");
    if (!btn || !drawer) return;
    btn.addEventListener("click", () => {
      const open = drawer.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", String(open));
    });
    drawer.querySelectorAll("a").forEach(a => {
      a.addEventListener("click", () => {
        drawer.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
      });
    });
  })();
</script>

<style>
  /* Position + slide animation shared by all nav states. */
  .nav-pill {
    top: 0.5rem;
    opacity: 1;
    transition: top 300ms ease-out, opacity 300ms ease-out;
  }
  .nav-pill.nav-pill--hidden {
    top: -96px;
    opacity: 0;
    pointer-events: none;
  }

  /* Default (scrolled) appearance — white pill + dark ink text + solid CTA. */
  .nav-pill .nav-pill-bg {
    background-color: #ffffff;
    transition: background-color 200ms ease, box-shadow 200ms ease;
  }
  .nav-pill .nav-text,
  .nav-pill .nav-text-hover {
    color: #000000;
  }
  .nav-pill .nav-text-hover:hover {
    background-color: rgba(0, 0, 0, 0.05);
  }
  .nav-pill .nav-cta {
    background-color: #00be50;     /* brand green */
    color: #ffffff;
  }
  .nav-pill .nav-cta:hover {
    background-color: #19d467;
  }

  /* Transparent (at-top-of-page) appearance — white text, no pill
     background, white-outlined "Get a Demo". */
  .nav-pill.nav-pill--transparent .nav-pill-bg {
    background-color: transparent;
    box-shadow: none;
  }
  .nav-pill.nav-pill--transparent .nav-text,
  .nav-pill.nav-pill--transparent .nav-text-hover {
    color: #ffffff;
  }
  .nav-pill.nav-pill--transparent .nav-text-hover:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }
  .nav-pill.nav-pill--transparent .nav-cta {
    background-color: transparent;
    color: #ffffff;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.75);
  }
  .nav-pill.nav-pill--transparent .nav-cta:hover {
    background-color: rgba(255, 255, 255, 0.08);
  }
</style>
