---
/**
 * Self-hosted video with lite-embed pattern:
 *   poster image + play button on initial render → click swaps in real <video>.
 * No third-party scripts, no YouTube branding, zero bytes until the user clicks.
 *
 * Usage:
 *   <VideoPlayer
 *     src="/videos/commercial.mp4"
 *     webm="/videos/commercial.webm"
 *     poster="/videos/commercial-poster.jpg"
 *     title="AskBobAI commercial"
 *   />
 */
interface Props {
  src: string;
  webm?: string;
  poster: string;
  title?: string;
  /** Tailwind aspect-ratio class. Defaults to video-native (16:9-ish). */
  ratio?: string;
}

const {
  src,
  webm,
  poster,
  title = "Play video",
  ratio = "aspect-[16/9]",
} = Astro.props;
---

<div
  class={`relative ${ratio} w-full rounded-xl overflow-hidden bg-black shadow-card group cursor-pointer`}
  data-video-embed
  data-src={src}
  data-webm={webm ?? ""}
  data-title={title}
>
  <img
    src={poster}
    alt={title}
    class="absolute inset-0 w-full h-full object-cover"
    loading="lazy"
  />
  <button
    type="button"
    class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/30 transition-colors"
    aria-label={title}
  >
    <span class="w-20 h-20 rounded-full bg-white/95 backdrop-blur flex items-center justify-center shadow-xl transition-transform group-hover:scale-110">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="var(--color-brand)" aria-hidden="true">
        <path d="M8 5v14l11-7z" />
      </svg>
    </span>
  </button>
</div>

<script is:inline>
  document.querySelectorAll("[data-video-embed]").forEach((el) => {
    el.addEventListener(
      "click",
      () => {
        const src = el.getAttribute("data-src");
        const webm = el.getAttribute("data-webm");
        const title = el.getAttribute("data-title") || "";
        const video = document.createElement("video");
        video.src = src;
        video.controls = true;
        video.autoplay = true;
        video.playsInline = true;
        video.className = "absolute inset-0 w-full h-full object-cover";
        video.setAttribute("aria-label", title);
        if (webm) {
          video.removeAttribute("src");
          const sWebm = document.createElement("source");
          sWebm.src = webm;
          sWebm.type = "video/webm";
          const sMp4 = document.createElement("source");
          sMp4.src = src;
          sMp4.type = "video/mp4";
          video.append(sWebm, sMp4);
        }
        el.innerHTML = "";
        el.appendChild(video);
      },
      { once: true }
    );
  });
</script>
