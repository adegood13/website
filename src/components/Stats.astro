---
/**
 * "Results You Can Measure" block — appears on all Platform, Industry, and
 * Function pages. Copy mirrors askbobai.com exactly: each card is a benefit
 * label + short description (no numeric counters — the live site uses a
 * qualitative pattern here).
 */
interface Stat { label: string; body: string; }
interface Props {
  eyebrow?: string;
  heading?: string;
  headingAccent?: string;
  subheading?: string;
  stats?: Stat[];
}

const {
  eyebrow = "Put Your Knowledge to Work",
  heading = "Results",
  headingAccent = "You Can Measure",
  subheading = "No hype. Just real impact your team will feel in week one.",
  stats = [
    { label: "Hours Saved",          body: "Fewer repeat questions, escalations, and internal back-and-forth." },
    { label: "Answer Accuracy",      body: "Answer-first responses grounded in your knowledge—consistent and defensible." },
    { label: "Knowledge Base Usage", body: "Instant answers that drive real adoption inside your workflow." },
  ],
} = Astro.props;
---

<section class="bg-blue-bg py-20 lg:py-28">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
    <div class="text-center max-w-2xl mx-auto mb-14">
      {eyebrow && (
        <p class="text-sm font-semibold uppercase tracking-wider text-brand mb-3">{eyebrow}</p>
      )}
      <h2 class="text-4xl lg:text-[54px] font-bold tracking-tight leading-[1.1]">
        {heading} <span class="text-brand">{headingAccent}</span>
      </h2>
      <p class="mt-4 text-ink-muted text-lg">{subheading}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {stats.map(stat => (
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-black/5 flex flex-col gap-4">
          <h3 class="text-2xl font-bold tracking-tight text-ink">{stat.label}</h3>
          <p class="text-ink-muted leading-relaxed">{stat.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
