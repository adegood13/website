---
/**
 * Base HTML shell — wraps every page.
 * Edit site-wide meta tags, analytics, and HubSpot script here.
 */
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  /** og:image path relative to /public, e.g. "/og/home.jpg" */
  ogImage?: string;
}

const {
  title,
  description = "The #1 AI platform for any department— turning your company knowledge into instant answers that save time and money.",
  ogImage = "/images/askbobai-og.jpg",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://askbobai.com");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicon (matches Framer source) -->
    <link rel="icon" type="image/svg+xml" href="/images/askbobai-logo.svg" />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Google Tag Manager -->
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-K96Q7JXP");
    </script>

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-G1CVKBX4QR"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("js", new Date());
      gtag("config", "G-G1CVKBX4QR");
    </script>
  </head>

  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- HubSpot tracking (portal 45488669) -->
    <script
      is:inline
      type="text/javascript"
      id="hs-script-loader"
      async
      defer
      src="//js.hs-scripts.com/45488669.js"
    ></script>
  </body>
</html>
